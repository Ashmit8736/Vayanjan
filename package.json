{
  "name": "vyanjan-desktop",
  "version": "1.0.0",
  "description": "Vyanjan Desktop Application - React + Electron",
  "main": "dist-electron/main.js",
  "author": "Vyanjan Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "vite",
    "electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron . --no-sandbox --disable-gpu",
    "dev": "concurrently -k \"cross-env BROWSER=none npm run start\" \"npm run electron\""
  },
  "dependencies": {
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.10",
    "@mui/material": "^5.15.10",
    "@reduxjs/toolkit": "^2.1.0",
    "axios": "^1.6.7",
    "dexie": "^3.2.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.vyanjan.desktop",
    "productName": "Vyanjan",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
